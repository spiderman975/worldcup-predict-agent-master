# ===== Python =====
__pycache__/
*.py[cod]
*.pyc
.pytest_cache/

# ===== 虚拟环境 =====
.venv/
venv/
env/

# ===== 环境变量 / 本地配置（可能含密钥，勿提交）=====
# 注意：.env.example 为示例文件，不受影响，会正常提交
.env
.env.local
.env.*.local

# ===== 前端依赖 / 构建产物 =====
node_modules/
dist/
build/

# ===== 数据库临时文件（WAL 运行时文件，必须忽略）=====
# 说明：主数据库 *.db / *.sqlite 会正常提交，仅忽略下面的临时文件
*.db-shm
*.db-wal

# ===== 数据快照 / 备份 =====
**/data/snapshots/*.json
**/.local_vector_store/
**/vector_store/

# ===== Agent 本地运行数据 =====
.agent_data/

# ===== 日志与调试文件 =====
*.log
debug-*.png
.edge-debug-profile/

# ===== 编辑器 / 操作系统 =====
.vscode/
.idea/
.DS_Store
Thumbs.db
