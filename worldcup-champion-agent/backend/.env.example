APP_NAME=WorldCup Agent
DATABASE_URL=sqlite:///./worldcup_agent.db
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

DEFAULT_MONTE_CARLO_RUNS=1000
MATCH_PREDICTION_CONCURRENCY=8

# LLM is off by default so local development keeps deterministic rule-based behavior.
LLM_ENABLED=false
LLM_API_KEY=
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus
LLM_AGENT_NAMES=PlannerAgent,DataScoutAgent,FootballAnalystAgent,NarratorAgent,CriticAgent
LLM_TIMEOUT_SECONDS=30
LLM_TEMPERATURE=0.25
LLM_MAX_TOKENS=900

# Backward-compatible provider variables. If LLM_API_KEY is empty,
# the backend can fall back to QWEN_API_KEY or DASHSCOPE_API_KEY.
QWEN_API_KEY=
DASHSCOPE_API_KEY=
QWEN_MODEL=qwen-plus
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

MY_CLAUDE_RUNTIME_ENABLED=true
BOCHA_API_KEY=

# Redis cache / lock / checkpoint hot storage.
# Set REDIS_ENABLED=false if you do not have Redis running locally.
REDIS_ENABLED=true
REDIS_URL=redis://localhost:6379/0
REDIS_KEY_PREFIX=worldcup-agent
REDIS_DEFAULT_TTL_SECONDS=900

# Checkpoints are persisted in SQLite and optionally mirrored into Redis.
CHECKPOINT_TTL_SECONDS=86400
CHECKPOINT_RUNNING_TIMEOUT_SECONDS=1800

# Scheduler windows.
SCHEDULER_ENABLED=true
SCHEDULER_POLL_SECONDS=60
PRE_MATCH_UPDATE_MINUTES=30
PRE_MATCH_INCLUDE_WEB=false
POST_MATCH_RESULT_HOURS=3
POST_MATCH_INCLUDE_WEB=true
